#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_handle_user_auth() {
  local ssh_user="${1:-}"
  local ssh_name="${2:-}"
  local ts
  local ssh_key_fingerprint
  local actor_name
  local actor_source
  local actor_type
  local actor_meta_json
  local hostname
  local subcommand
  local app
  local container_type
  local container_id
  local general_args_json
  local match_args_json
  local command_text
  local meta_json
  local message
  local event_kind
  local follow_on_event_count=0
  local -a command_tokens=()
  local -a sanitized_tokens=()
  local token
  local -a parsed_match_args=()
  local parsed_app=""
  local parsed_subcommand=""
  local parsed_container_type=""
  local parsed_container_id=""

  shift 2 || true
  while IFS= read -r token; do
    [[ -n "$token" ]] || continue
    command_tokens+=("$token")
  done < <(audit_command_tokens_lines "$@")

  [[ "${#command_tokens[@]}" -gt 0 ]] || return 0

  ts="$(audit_now_utc)"
  actor_name="$(audit_actor_name_from_ssh_context "$ssh_name" "$ssh_user")"
  actor_source="$(audit_actor_source_from_ssh_context "$ssh_name" "$ssh_user")"
  ssh_key_fingerprint="$(audit_resolve_ssh_key_fingerprint "$ssh_name")"
  actor_type="$(audit_actor_type_from_name "$actor_name")"
  actor_meta_json="$(audit_actor_identity_meta_json "$actor_source" "$ssh_user" "$ssh_name" "$ssh_key_fingerprint")"
  hostname="$(audit_hostname)"

  audit_parse_dokku_invocation "${command_tokens[@]}"
  parsed_subcommand="$AUDIT_PARSED_SUBCOMMAND"
  parsed_app="$AUDIT_PARSED_APP"
  parsed_container_type="$AUDIT_PARSED_CONTAINER_TYPE"
  parsed_container_id="$AUDIT_PARSED_CONTAINER_ID"
  parsed_match_args=("${AUDIT_PARSED_MATCH_ARGS[@]}")

  if ! audit_should_record_user_auth_command "$parsed_subcommand" "$parsed_app" "${AUDIT_PARSED_COMMAND_ARGS[@]}"; then
    return 0
  fi

  while IFS= read -r token; do
    [[ -n "$token" ]] || continue
    sanitized_tokens+=("$token")
  done < <(audit_sanitized_dokku_command_tokens_lines "${command_tokens[@]}")

  audit_parse_dokku_invocation "${sanitized_tokens[@]}"
  subcommand="$AUDIT_PARSED_SUBCOMMAND"
  app="$parsed_app"
  container_type="$parsed_container_type"
  container_id="$parsed_container_id"
  general_args_json="$(audit_json_array_from_args "${AUDIT_PARSED_COMMAND_ARGS[@]}")"
  match_args_json="$(audit_json_array_from_args "${parsed_match_args[@]}")"
  command_text="$(audit_prefixed_dokku_command_text "${sanitized_tokens[@]}")"
  message="$(audit_message_for_command_invoke "$command_text" "$subcommand")"
  meta_json="$(audit_json_patch_objects "$(audit_command_event_meta_json "$actor_source" "$command_text" "$subcommand" "$general_args_json" "$container_type" "$container_id" "$hostname" "authorized")" "$(audit_json_remove_key "$actor_meta_json" '$.actor_source')")"

  while IFS= read -r event_kind; do
    [[ -n "$event_kind" ]] || continue
    follow_on_event_count=$((follow_on_event_count + 1))
    audit_store_pending_event_actor_context "$app" "$event_kind" "$subcommand" "$command_text" "$actor_type" "$actor_name" "$actor_meta_json" "$ts"
  done < <(audit_follow_on_event_kinds_lines "$subcommand" "$app" "${AUDIT_PARSED_TRAILING_TOKENS[@]}")

  case "$subcommand" in
    run|enter)
      [[ -n "$app" ]] || return 0
      audit_store_pending_command_context "$app" "$subcommand" "$command_text" "$match_args_json" "$actor_type" "$actor_name" "$actor_source" "$actor_meta_json" "$hostname" "$ts"
      return 0
      ;;
  esac

  if [[ "$follow_on_event_count" -gt 0 ]]; then
    return 0
  fi

  audit_insert_event "$app" "command" "invoke" "success" "dokku_command" "user-auth" "" "" "" "$actor_type" "$actor_name" "" "$message" "$meta_json" "$ts" "$ts"
}

audit_trigger_guard "user-auth" "" audit_handle_user_auth "$@"
