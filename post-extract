#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_handle_post_extract() {
  local app="$1"
  local tmp_work_dir="${2:-}"
  local rev="${3:-}"
  local ts
  local actor_type="system"
  local actor_name=""
  local meta_json

  [[ -n "$app" ]] || audit_die "missing app name"

  ts="$(audit_now_utc)"
  meta_json="{\"rev\":$(audit_json_or_null "$rev") }"
  audit_claim_pending_event_actor_context "$app" "deploy-extract" "$ts"
  actor_type="$AUDIT_CONTEXT_ACTOR_TYPE"
  actor_name="$AUDIT_CONTEXT_ACTOR_NAME"
  meta_json="$(audit_json_patch_objects "$meta_json" "$AUDIT_CONTEXT_ACTOR_META_JSON")"
  audit_db_exec "BEGIN IMMEDIATE;
UPDATE pending_deploys
SET
  rev = COALESCE($(audit_sql_nullable "$rev"), rev),
  updated_ts = $(audit_sql_quote "$ts")
WHERE app = $(audit_sql_quote "$app");
INSERT INTO events (
  ts,
  app,
  category,
  action,
  status,
  classification,
  source_trigger,
  source_type,
  image_tag,
  rev,
  actor_type,
  actor_name,
  correlation_id,
  message,
  meta_json,
  created_at
) VALUES (
  $(audit_sql_quote "$ts"),
  $(audit_sql_quote "$app"),
  'deploy',
  'extract',
  'success',
  'source_extracted',
  'post-extract',
  (SELECT source_type FROM pending_deploys WHERE app = $(audit_sql_quote "$app") LIMIT 1),
  NULL,
  $(audit_sql_nullable "$rev"),
  $(audit_sql_quote "$actor_type"),
  $(audit_sql_nullable "$actor_name"),
  (SELECT correlation_id FROM pending_deploys WHERE app = $(audit_sql_quote "$app") LIMIT 1),
  'source extracted',
  $(audit_sql_quote "$meta_json"),
  $(audit_sql_quote "$ts")
);
COMMIT;"

  : "$tmp_work_dir"
}

audit_trigger_guard "post-extract" "${1:-}" audit_handle_post_extract "$@"
