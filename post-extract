#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_handle_post_extract() {
  local app="$1"
  local tmp_work_dir="${2:-}"
  local rev="${3:-}"
  local ts
  local correlation_id
  local inferred_source_type

  [[ -n "$app" ]] || audit_die "missing app name"

  ts="$(audit_now_utc)"
  audit_claim_pending_event_actor_context "$app" "deploy-extract" "$ts"
  correlation_id="$(audit_pending_correlation_id "$app")"
  if [[ -z "$correlation_id" ]]; then
    correlation_id="$(audit_generate_correlation_id)"
  fi
  inferred_source_type="$(audit_inferred_source_type_from_actor_meta_json "$AUDIT_CONTEXT_ACTOR_META_JSON")"
  audit_upsert_pending_deploy "$app" "$correlation_id" "$inferred_source_type" "$rev" '{}' "$ts"

  : "$tmp_work_dir"
}

audit_trigger_guard "post-extract" "${1:-}" audit_handle_post_extract "$@"
