#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_handle_deploy_source_set() {
  local app="$1"
  local source_type="$2"
  shift 2 || true
  local metadata_raw="$*"
  local ts
  local correlation_id
  local metadata_json='{}'
  local recent_finish_id
  local recent_finish_correlation_id

  [[ -n "$app" ]] || audit_die "missing app name"
  [[ -n "$source_type" ]] || audit_die "missing source type"

  ts="$(audit_now_utc)"
  audit_claim_pending_event_actor_context "$app" "deploy-source-set" "$ts"
  correlation_id="$(audit_pending_correlation_id "$app")"
  if [[ -n "$metadata_raw" ]]; then
    metadata_json="{\"deploy_metadata_raw\":$(audit_json_string "$metadata_raw") }"
  fi

  if [[ -n "$correlation_id" ]]; then
    audit_upsert_pending_deploy "$app" "$correlation_id" "$source_type" "" "$metadata_json" "$ts"
    return 0
  fi

  recent_finish_id="$(audit_recent_deploy_finish_id "$app" "$ts")"
  if [[ -n "$recent_finish_id" ]]; then
    recent_finish_correlation_id="$(audit_db_query_single "SELECT COALESCE(correlation_id, '') FROM events WHERE id = $(audit_sql_quote "$recent_finish_id") LIMIT 1;")"
    if [[ -z "$recent_finish_correlation_id" ]]; then
      recent_finish_correlation_id="$(audit_generate_correlation_id)"
    fi

    audit_patch_deploy_finish_from_source_metadata "$recent_finish_id" "$recent_finish_correlation_id" "$source_type" "$metadata_json"
    return 0
  fi

  correlation_id="$(audit_generate_correlation_id)"
  audit_upsert_pending_deploy "$app" "$correlation_id" "$source_type" "" "$metadata_json" "$ts"
}

audit_trigger_guard "deploy-source-set" "${1:-}" audit_handle_deploy_source_set "$@"
