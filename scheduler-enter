#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_handle_scheduler_enter() {
  local scheduler="${1:-}"
  local app="${2:-}"
  local ts
  local match_args_json
  local args_json
  local claim
  local actor_type="system"
  local actor_name=""
  local actor_source=""
  local command_text=""
  local hostname=""
  local meta_json

  : "$scheduler"
  [[ -n "$app" ]] || audit_die "missing app name"
  shift 2 || true

  ts="$(audit_now_utc)"
  match_args_json="$(audit_json_array_from_args "$@")"
  claim="$(audit_claim_pending_command_context "$app" "enter" "$match_args_json" "$ts")"
  if [[ -n "$claim" ]]; then
    IFS=$'\t' read -r _ actor_type actor_name actor_source command_text hostname _ <<< "$claim"
  fi

  audit_parse_enter_arguments "$app" "$@"
  args_json="$(audit_json_array_from_args "${AUDIT_PARSED_COMMAND_ARGS[@]}")"

  if [[ -z "$command_text" ]]; then
    command_text="$(audit_prefixed_dokku_command_text enter "$app" "$@")"
  fi
  if [[ -z "$hostname" ]]; then
    hostname="$(audit_hostname)"
  fi

  meta_json="$(audit_command_event_meta_json "$actor_source" "$command_text" "enter" "$args_json" "$AUDIT_PARSED_CONTAINER_TYPE" "$AUDIT_PARSED_CONTAINER_ID" "$hostname" "enter_requested")"
  audit_insert_event "$app" "command" "enter" "success" "dokku_enter" "scheduler-enter" "" "" "" "$actor_type" "$actor_name" "" "$(audit_message_for_enter)" "$meta_json" "$ts" "$ts"
}

audit_trigger_guard "scheduler-enter" "${2:-}" audit_handle_scheduler_enter "$@"
