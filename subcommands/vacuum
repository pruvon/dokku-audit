#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/../bootstrap"

audit_require_database

audit_db_exec 'VACUUM; PRAGMA optimize;'
audit_meta_set "last_optimize_at" "$(audit_now_utc)"
audit_insert_maintenance_event "vacuum" "maintenance_vacuum" "vacuum completed" '{"optimize":true}'
printf 'vacuum completed\n'
