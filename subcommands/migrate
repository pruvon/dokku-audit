#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_AVAILABLE_PATH="${PLUGIN_AVAILABLE_PATH:-$(cd "$AUDIT_SCRIPT_DIR/.." && pwd)}"

if [[ -n "${PLUGIN_CORE_AVAILABLE_PATH:-}" ]] && [[ -f "$PLUGIN_CORE_AVAILABLE_PATH/common/functions" ]]; then
  # shellcheck source=/dev/null
  source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
fi

# shellcheck source=/dev/null
source "$PLUGIN_AVAILABLE_PATH/functions"

dry_run=false
verbose=false

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=true
      ;;
    --verbose)
      verbose=true
      ;;
    *)
      audit_die "unknown argument: $1"
      exit 1
      ;;
  esac
  shift
done

output="$(audit_run_migrations "$dry_run" "$verbose")"
if audit_is_true "$dry_run" || audit_is_true "$verbose"; then
  printf '%s\n' "$output"
else
  printf 'schema version: %s\n' "$output"
fi