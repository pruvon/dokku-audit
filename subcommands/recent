#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/../bootstrap"

audit_require_database

limit=20
category=""
classification=""
status=""
since=""
format="table"
quiet=false

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --limit)
      limit="$2"
      shift
      ;;
    --category)
      category="$2"
      shift
      ;;
    --classification)
      classification="$2"
      shift
      ;;
    --status)
      status="$2"
      shift
      ;;
    --since)
      since="$2"
      shift
      ;;
    --format)
      format="$2"
      shift
      ;;
    --quiet)
      quiet=true
      ;;
    *)
      audit_die "unknown argument: $1"
      exit 1
      ;;
  esac
  shift
done

[[ "$limit" =~ ^[0-9]+$ ]] || audit_die "--limit must be a positive integer"

where_clause="1 = 1"
if [[ -n "$category" ]]; then
  where_clause+=" AND category = $(audit_sql_quote "$category")"
fi
if [[ -n "$classification" ]]; then
  where_clause+=" AND classification = $(audit_sql_quote "$classification")"
fi
if [[ -n "$status" ]]; then
  where_clause+=" AND status = $(audit_sql_quote "$status")"
fi
if [[ -n "$since" ]]; then
  where_clause+=" AND ts >= $(audit_sql_quote "$since")"
fi

event_json_sql="$(audit_event_json_sql)"
table_sql="SELECT id, ts, COALESCE(app, '-'), category, action, COALESCE(classification, '-'), status, COALESCE(message, '-') FROM events WHERE ${where_clause} ORDER BY ts DESC LIMIT ${limit};"
jsonl_sql="SELECT ${event_json_sql} FROM events WHERE ${where_clause} ORDER BY ts DESC LIMIT ${limit};"
json_sql="SELECT COALESCE(json_group_array(json(event_json)), '[]') FROM (SELECT ${event_json_sql} AS event_json FROM events WHERE ${where_clause} ORDER BY ts DESC LIMIT ${limit});"

audit_emit_query_output "$format" $'ID\tTIME\tAPP\tCATEGORY\tACTION\tCLASSIFICATION\tSTATUS\tMESSAGE' "$table_sql" "$jsonl_sql" "$json_sql" "" "$quiet"
