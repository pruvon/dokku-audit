#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/../bootstrap"

audit_require_database

if audit_is_command_invocation "report-deploy-status" "${1:-}"; then
  shift
fi

app="${1:-}"
deploy_status="${2:-}"

[[ -n "$app" ]] || audit_die "missing app name"
[[ -n "$deploy_status" ]] || audit_die "missing deploy status"

# Successful completions are already recorded by post-deploy
if [[ "$deploy_status" == "success" ]]; then
  exit 0
fi

ts="$(audit_now_utc)"
app_sql="$(audit_sql_quote "$app")"

audit_claim_pending_event_actor_context "$app" "deploy-finish" "$ts"
actor_type="$AUDIT_CONTEXT_ACTOR_TYPE"
actor_name="$AUDIT_CONTEXT_ACTOR_NAME"

message="deploy failed: ${deploy_status}"
meta_json="{\"deploy_status\":$(audit_json_string "$deploy_status")}"
meta_json="$(audit_json_patch_objects "$meta_json" "$AUDIT_CONTEXT_ACTOR_META_JSON")"

# Also clean up any stale pending deploy row since this deploy did not complete
audit_db_exec "BEGIN IMMEDIATE;
INSERT INTO events (
  ts,
  app,
  category,
  action,
  status,
  classification,
  source_trigger,
  source_type,
  image_tag,
  rev,
  actor_type,
  actor_name,
  correlation_id,
  message,
  meta_json,
  created_at
) VALUES (
  $(audit_sql_quote "$ts"),
  $app_sql,
  'deploy',
  'finish',
  'error',
  'deploy_failed',
  'report-deploy-status',
  (SELECT source_type FROM pending_deploys WHERE app = $app_sql LIMIT 1),
  NULL,
  (SELECT rev FROM pending_deploys WHERE app = $app_sql LIMIT 1),
  $(audit_sql_quote "$actor_type"),
  $(audit_sql_nullable "$actor_name"),
  (SELECT correlation_id FROM pending_deploys WHERE app = $app_sql LIMIT 1),
  $(audit_sql_nullable "$message"),
  $(audit_sql_quote "$meta_json"),
  $(audit_sql_quote "$ts")
);
DELETE FROM pending_deploys WHERE app = $app_sql;
COMMIT;"
