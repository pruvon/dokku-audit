#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_AVAILABLE_PATH="${PLUGIN_AVAILABLE_PATH:-$(cd "$AUDIT_SCRIPT_DIR/.." && pwd)}"

if [[ -n "${PLUGIN_CORE_AVAILABLE_PATH:-}" ]] && [[ -f "$PLUGIN_CORE_AVAILABLE_PATH/common/functions" ]]; then
  # shellcheck source=/dev/null
  source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
fi

# shellcheck source=/dev/null
source "$PLUGIN_AVAILABLE_PATH/functions"

audit_require_database

limit=20
app=""
classification=""
format="table"
quiet=false

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --limit)
      limit="$2"
      shift
      ;;
    --app)
      app="$2"
      shift
      ;;
    --classification)
      classification="$2"
      shift
      ;;
    --format)
      format="$2"
      shift
      ;;
    --quiet)
      quiet=true
      ;;
    *)
      audit_die "unknown argument: $1"
      exit 1
      ;;
  esac
  shift
done

[[ "$limit" =~ ^[0-9]+$ ]] || audit_die "--limit must be a positive integer"

where_clause="category = 'deploy' AND action = 'finish'"
if [[ -n "$app" ]]; then
  where_clause+=" AND app = $(audit_sql_quote "$app")"
fi
if [[ -n "$classification" ]]; then
  where_clause+=" AND classification = $(audit_sql_quote "$classification")"
fi

event_json_sql="$(audit_event_json_sql)"
table_sql="SELECT id, ts, COALESCE(app, '-'), COALESCE(classification, '-'), COALESCE(source_type, '-'), COALESCE(substr(rev, 1, 12), '-'), COALESCE(image_tag, '-') FROM events WHERE ${where_clause} ORDER BY ts DESC LIMIT ${limit};"
jsonl_sql="SELECT ${event_json_sql} FROM events WHERE ${where_clause} ORDER BY ts DESC LIMIT ${limit};"
json_sql="SELECT COALESCE(json_group_array(json(event_json)), '[]') FROM (SELECT ${event_json_sql} AS event_json FROM events WHERE ${where_clause} ORDER BY ts DESC LIMIT ${limit});"

audit_emit_query_output "$format" $'ID\tTIME\tAPP\tCLASSIFICATION\tSOURCE_TYPE\tREV\tIMAGE_TAG' "$table_sql" "$jsonl_sql" "$json_sql" "" "$quiet"