#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/../bootstrap"

issues=()
oks=()
db_path="$(audit_db_path)"

if audit_has_command sqlite3; then
  oks+=("sqlite3 executable available")
else
  issues+=("sqlite3 executable is missing")
fi

if [[ -f "$db_path" && -r "$db_path" ]]; then
  oks+=("database accessible at $db_path")
else
  issues+=("database is not accessible at $db_path")
fi

if [[ -f "$db_path" && -r "$db_path" ]]; then
  app_id="$(audit_application_id_current 2>/dev/null || true)"
  if [[ "$app_id" == "$AUDIT_APPLICATION_ID" ]]; then
    oks+=("application_id matches $AUDIT_APPLICATION_ID")
  else
    issues+=("application_id mismatch: expected $AUDIT_APPLICATION_ID, got ${app_id:-unreadable}")
  fi

  user_version="$(audit_user_version 2>/dev/null || true)"
  target_version="$(audit_latest_migration_version)"
  if [[ "$user_version" =~ ^[0-9]+$ ]] && (( user_version >= 1 )) && (( user_version <= target_version )); then
    oks+=("schema version is $user_version")
  else
    issues+=("unexpected schema version: ${user_version:-unreadable}")
  fi

  for table_name in events pending_deploys pending_command_contexts pending_event_actor_contexts pending_runtime_events meta; do
    if audit_table_exists "$table_name"; then
      oks+=("table present: $table_name")
    else
      issues+=("missing table: $table_name")
    fi
  done

  for index_name in idx_events_ts idx_events_app_ts idx_events_category_ts idx_events_classification_ts idx_events_rev idx_events_correlation_id idx_pending_command_contexts_lookup idx_pending_event_actor_contexts_updated_at idx_pending_runtime_events_event_id idx_pending_runtime_events_lookup; do
    if audit_index_exists "$index_name"; then
      oks+=("index present: $index_name")
    else
      issues+=("missing index: $index_name")
    fi
  done

  journal_mode="$(audit_journal_mode 2>/dev/null || true)"
  if [[ -n "$journal_mode" ]]; then
    oks+=("journal mode: $journal_mode")
  else
    issues+=("journal mode could not be determined")
  fi

  integrity_check="$(audit_db_query_single 'PRAGMA integrity_check;' 2>/dev/null || true)"
  if [[ "$integrity_check" == "ok" ]]; then
    oks+=("integrity_check returned ok")
  else
    issues+=("integrity_check failed: ${integrity_check:-unreadable}")
  fi

  stale_pending_count="$(audit_db_query_single "SELECT COUNT(1) FROM pending_deploys WHERE first_seen_ts < strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-$(audit_pending_stale_threshold_seconds) seconds');" 2>/dev/null || true)"
  if [[ "$stale_pending_count" =~ ^[0-9]+$ ]] && (( stale_pending_count == 0 )); then
    oks+=("no stale pending deploy rows")
  else
    issues+=("stale pending deploy rows detected: ${stale_pending_count:-unreadable}")
  fi

  stale_command_context_count="$(audit_db_query_single "SELECT COUNT(1) FROM pending_command_contexts WHERE created_at < strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-$(audit_pending_stale_threshold_seconds) seconds');" 2>/dev/null || true)"
  if [[ "$stale_command_context_count" =~ ^[0-9]+$ ]] && (( stale_command_context_count == 0 )); then
    oks+=("no stale pending command context rows")
  else
    issues+=("stale pending command context rows detected: ${stale_command_context_count:-unreadable}")
  fi

  stale_runtime_event_count="$(audit_db_query_single "SELECT COUNT(1) FROM pending_runtime_events WHERE created_at < strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-$(audit_pending_stale_threshold_seconds) seconds');" 2>/dev/null || true)"
  if [[ "$stale_runtime_event_count" =~ ^[0-9]+$ ]] && (( stale_runtime_event_count == 0 )); then
    oks+=("no stale pending runtime event rows")
  else
    issues+=("stale pending runtime event rows detected: ${stale_runtime_event_count:-unreadable}")
  fi

  stale_event_actor_context_count="$(audit_db_query_single "SELECT COUNT(1) FROM pending_event_actor_contexts WHERE updated_at < strftime('%Y-%m-%dT%H:%M:%SZ', 'now', '-$(audit_pending_stale_threshold_seconds) seconds');" 2>/dev/null || true)"
  if [[ "$stale_event_actor_context_count" =~ ^[0-9]+$ ]] && (( stale_event_actor_context_count == 0 )); then
    oks+=("no stale pending event actor context rows")
  else
    issues+=("stale pending event actor context rows detected: ${stale_event_actor_context_count:-unreadable}")
  fi

  page_count="$(audit_db_query_single 'PRAGMA page_count;' 2>/dev/null || true)"
  freelist_count="$(audit_db_query_single 'PRAGMA freelist_count;' 2>/dev/null || true)"
  if [[ "$page_count" =~ ^[0-9]+$ && "$freelist_count" =~ ^[0-9]+$ ]]; then
    oks+=("database pages: ${page_count} (freelist: ${freelist_count})")
  fi

  wal_path="${db_path}-wal"
  if [[ -f "$wal_path" ]]; then
    wal_size="$(stat -f '%z' "$wal_path" 2>/dev/null || stat -c '%s' "$wal_path" 2>/dev/null || true)"
    if [[ "$wal_size" =~ ^[0-9]+$ ]]; then
      wal_size_mb=$((wal_size / 1048576))
      if [[ "$wal_size_mb" -gt 100 ]]; then
        issues+=("WAL file is unusually large: ${wal_size_mb}MB (${wal_path})")
      else
        oks+=("WAL file size: ${wal_size_mb}MB")
      fi
    fi
  fi
fi

for ok_item in "${oks[@]}"; do
  printf 'ok: %s\n' "$ok_item"
done

for issue_item in "${issues[@]}"; do
  printf 'issue: %s\n' "$issue_item"
done

if [[ "${#issues[@]}" -gt 0 ]]; then
  exit 1
fi
