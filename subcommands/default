#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AUDIT_PLUGIN_ROOT="$(cd "$AUDIT_SCRIPT_DIR/.." && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_PLUGIN_ROOT/bootstrap"

if audit_is_command_invocation "default" "${1:-}"; then
  shift
fi

exec "$AUDIT_PLUGIN_ROOT/subcommands/status" "$@"
