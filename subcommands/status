#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/../bootstrap"

audit_require_sqlite
audit_require_database

last_migration_timestamp="$(audit_meta_get last_migration_at 2>/dev/null || true)"
if [[ -z "$last_migration_timestamp" ]]; then
  last_migration_timestamp='-'
fi

printf 'plugin version: %s\n' "$(audit_plugin_version)"
printf 'database path: %s\n' "$(audit_db_path)"
printf 'application id: %s\n' "$(audit_application_id_current)"
printf 'schema version: %s\n' "$(audit_user_version)"
printf 'journal mode: %s\n' "$(audit_journal_mode)"
printf 'total events: %s\n' "$(audit_db_query_single 'SELECT COUNT(1) FROM events;')"
printf 'pending deploy count: %s\n' "$(audit_db_query_single 'SELECT COUNT(1) FROM pending_deploys;')"
printf 'last event timestamp: %s\n' "$(audit_db_query_single 'SELECT COALESCE(MAX(ts), "-") FROM events;')"
printf 'last migration timestamp: %s\n' "$last_migration_timestamp"
