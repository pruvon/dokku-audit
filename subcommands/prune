#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/../bootstrap"

audit_require_database

if audit_is_command_invocation "prune" "${1:-}"; then
  shift
fi

older_than=""
category=""
classification=""
confirmed=false
schedule=false
unschedule=false

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --older-than)
      older_than="$2"
      shift
      ;;
    --category)
      category="$2"
      shift
      ;;
    --classification)
      classification="$2"
      shift
      ;;
    --yes)
      confirmed=true
      ;;
    --schedule)
      schedule=true
      ;;
    --unschedule)
      unschedule=true
      ;;
    *)
      audit_die "unknown argument: $1"
      ;;
  esac
  shift
done

if audit_is_true "$unschedule"; then
  audit_meta_set "prune_schedule_older_than" ""
  audit_meta_set "prune_schedule_category" ""
  audit_meta_set "prune_schedule_classification" ""
  printf 'prune schedule removed\n'
  exit 0
fi

if audit_is_true "$schedule"; then
  [[ -n "$older_than" ]] || audit_die "--older-than is required with --schedule"
  [[ "$older_than" =~ ^[0-9]+$ ]] || audit_die "--older-than must be a positive integer"
  audit_meta_set "prune_schedule_older_than" "$older_than"
  audit_meta_set "prune_schedule_category" "$category"
  audit_meta_set "prune_schedule_classification" "$classification"
  printf 'prune schedule configured: older-than=%s' "$older_than"
  [[ -n "$category" ]] && printf ' category=%s' "$category"
  [[ -n "$classification" ]] && printf ' classification=%s' "$classification"
  printf '\n'
  printf 'add a cron job to run: dokku audit:prune --older-than %s' "$older_than"
  [[ -n "$category" ]] && printf ' --category %s' "$category"
  [[ -n "$classification" ]] && printf ' --classification %s' "$classification"
  printf ' --yes\n'
  exit 0
fi

[[ -n "$older_than" ]] || audit_die "usage: dokku audit:prune --older-than DAYS [--category VALUE] [--classification VALUE] [--yes] [--schedule] [--unschedule]"
[[ "$older_than" =~ ^[0-9]+$ ]] || audit_die "--older-than must be a positive integer"
audit_is_true "$confirmed" || audit_die "refusing to prune without --yes"

cutoff="$(audit_days_ago_utc "$older_than")"
where_clause="ts < $(audit_sql_quote "$cutoff")"
if [[ -n "$category" ]]; then
  where_clause+=" AND category = $(audit_sql_quote "$category")"
fi
if [[ -n "$classification" ]]; then
  where_clause+=" AND classification = $(audit_sql_quote "$classification")"
fi

ts="$(audit_now_utc)"
actor_name="$(audit_safe_local_actor_name)"
actor_source="$(audit_safe_local_actor_source)"
actor_type="$(audit_actor_type_from_name "$actor_name")"
meta_json="$(audit_json_patch_objects "{\"older_than_days\":${older_than}}" "$(audit_local_actor_meta_json "$actor_source")")"

deleted_count="$(audit_db_query_single "BEGIN IMMEDIATE;
CREATE TEMP TABLE audit_prune_meta AS
  SELECT MIN(id) AS min_id, MAX(id) AS max_id FROM events WHERE ${where_clause};
DELETE FROM events WHERE ${where_clause};
CREATE TEMP TABLE audit_prune_state(value INTEGER NOT NULL);
INSERT INTO audit_prune_state(value) SELECT changes();
INSERT INTO events (
  ts,
  app,
  category,
  action,
  status,
  classification,
  source_trigger,
  source_type,
  image_tag,
  rev,
  actor_type,
  actor_name,
  correlation_id,
  message,
  meta_json,
  created_at
) VALUES (
  $(audit_sql_quote "$ts"),
  NULL,
  'maintenance',
  'prune',
  'success',
  'maintenance_prune',
  'manual',
  NULL,
  NULL,
  NULL,
  $(audit_sql_quote "$actor_type"),
  $(audit_sql_nullable "$actor_name"),
  NULL,
  'prune completed',
  json_patch(
    json_patch(
      json($(audit_sql_quote "$meta_json")),
      json_object('deleted_count', (SELECT value FROM audit_prune_state LIMIT 1))
    ),
    COALESCE(
      (SELECT json_object('min_id', min_id, 'max_id', max_id) FROM audit_prune_meta WHERE min_id IS NOT NULL LIMIT 1),
      '{}'
    )
  ),
  $(audit_sql_quote "$ts")
);
SELECT value FROM audit_prune_state LIMIT 1;
DROP TABLE audit_prune_state;
DROP TABLE audit_prune_meta;
COMMIT;")"

printf 'deleted events: %s\n' "$deleted_count"
