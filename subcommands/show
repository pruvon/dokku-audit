#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/../bootstrap"

audit_require_database

if audit_is_command_invocation "show" "${1:-}"; then
  shift
fi

event_id="${1:-}"
[[ -n "$event_id" ]] || audit_die "usage: dokku audit:show <event-id> [--format table|json]"
shift || true

format="table"
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --format)
      format="$2"
      shift
      ;;
    *)
      audit_die "unknown argument: $1"
      exit 1
      ;;
  esac
  shift
done

[[ "$event_id" =~ ^[0-9]+$ ]] || audit_die "event id must be numeric"

event_json_sql="$(audit_event_json_sql)"
json_output="$(audit_db_query_single "SELECT ${event_json_sql} FROM events WHERE id = ${event_id} LIMIT 1;")"
[[ -n "$json_output" ]] || audit_die "event not found: $event_id"

if [[ "$format" == "json" ]]; then
  printf '%s\n' "$json_output"
  exit 0
fi

if audit_has_command python3; then
  printf '%s\n' "$json_output" | python3 <<'PY'
import json
import sys

payload = json.load(sys.stdin)
meta_payload = payload.get("meta", {})
meta = json.dumps(meta_payload, indent=2, sort_keys=True)
mapping = [
    ("id", payload.get("id")),
    ("ts", payload.get("ts")),
    ("app", payload.get("app") or "-"),
    ("actor", payload.get("actor_label") or payload.get("actor_name") or payload.get("actor_type") or "-"),
    ("category", payload.get("category")),
    ("action", payload.get("action")),
    ("status", payload.get("status")),
    ("classification", payload.get("classification") or "-"),
    ("source trigger", payload.get("source_trigger")),
    ("source type", payload.get("source_type") or "-"),
    ("image tag", payload.get("image_tag") or "-"),
    ("rev", payload.get("rev") or "-"),
    ("actor type", payload.get("actor_type")),
    ("actor name", payload.get("actor_name") or "-"),
    ("actor source", meta_payload.get("actor_source") or "-"),
    ("sudo user", meta_payload.get("sudo_user") or "-"),
    ("local user", meta_payload.get("local_user") or "-"),
    ("effective user", meta_payload.get("effective_user") or "-"),
    ("process tree user", meta_payload.get("process_tree_user") or "-"),
    ("ssh user", meta_payload.get("ssh_user") or "-"),
    ("ssh name", meta_payload.get("ssh_name") or "-"),
    ("ssh key fingerprint", meta_payload.get("ssh_key_fingerprint") or "-"),
    ("triggered by", meta_payload.get("triggered_by_command") or "-"),
    ("correlation id", payload.get("correlation_id") or "-"),
    ("message", payload.get("message") or "-"),
    ("created at", payload.get("created_at")),
]

for key, value in mapping:
    print("{}: {}".format(key, value))
print("meta_json:")
print(meta)
PY
  exit 0
fi

printf '%s\n' "$json_output"
