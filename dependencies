#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_require_sqlite

if ! audit_has_command flock; then
  audit_warn "flock executable not found; using mkdir-based lock fallback"
fi

audit_log "${AUDIT_PLUGIN_NAME}: dependencies ok"
