#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_handle_post_proxy_ports_update() {
  local app="$1"
  local action="$2"
  shift 2 || true
  local ts
  local actor_type="system"
  local actor_name=""
  local meta_json='{}'

  [[ -n "$app" ]] || audit_die "missing app name"
  [[ -n "$action" ]] || audit_die "missing ports action"

  ts="$(audit_now_utc)"
  if [[ "$#" -gt 0 ]]; then
    meta_json="{\"port_mapping_count\":$#,\"details_redacted\":true}"
  fi
  audit_claim_pending_event_actor_context "$app" "ports" "$ts"
  actor_type="$AUDIT_CONTEXT_ACTOR_TYPE"
  actor_name="$AUDIT_CONTEXT_ACTOR_NAME"
  meta_json="$(audit_json_patch_objects "$meta_json" "$AUDIT_CONTEXT_ACTOR_META_JSON")"

  audit_insert_event "$app" "ports" "$action" "success" "ports_change" "post-proxy-ports-update" "" "" "" "$actor_type" "$actor_name" "" "$(audit_message_for_ports_change "$action")" "$meta_json" "$ts" "$ts"
}

audit_trigger_guard "post-proxy-ports-update" "${1:-}" audit_handle_post_proxy_ports_update "$@"
