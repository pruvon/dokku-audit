#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_AVAILABLE_PATH="${PLUGIN_AVAILABLE_PATH:-$AUDIT_SCRIPT_DIR}"

if [[ -n "${PLUGIN_CORE_AVAILABLE_PATH:-}" ]] && [[ -f "$PLUGIN_CORE_AVAILABLE_PATH/common/functions" ]]; then
  # shellcheck source=/dev/null
  source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
fi

# shellcheck source=/dev/null
source "$PLUGIN_AVAILABLE_PATH/functions"

audit_handle_app_create() {
  local app="$1"

  [[ -n "$app" ]] || audit_die "missing app name"
  audit_insert_event "$app" "app" "create" "success" "app_create" "app-create" "" "" "" "system" "" "" "app created" '{}'
}

audit_trigger_guard "app-create" "${1:-}" audit_handle_app_create "$@"