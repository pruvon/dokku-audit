audit_claim_pending_command_context() {
  local app="$1"
  local subcommand="$2"
  local args_json="$3"
  local ts="${4:-$(audit_now_utc)}"

  if [[ -z "$args_json" ]]; then
    args_json='[]'
  fi

  sqlite3 -tabs "$(audit_db_path)" <<SQL
.timeout $(audit_busy_timeout_ms)
PRAGMA foreign_keys = ON;
BEGIN IMMEDIATE;
DELETE FROM pending_command_contexts
WHERE created_at < strftime('%Y-%m-%dT%H:%M:%SZ', $(audit_sql_quote "$ts"), '-$(audit_pending_stale_threshold_seconds) seconds');
SELECT id, actor_type, COALESCE(actor_name, ''), COALESCE(actor_source, ''), command_text, COALESCE(hostname, ''), created_at
FROM pending_command_contexts
WHERE subcommand = $(audit_sql_quote "$subcommand")
  AND COALESCE(app, '') = $(audit_sql_quote "$app")
  AND args_json = $(audit_sql_quote "$args_json")
  AND created_at >= strftime('%Y-%m-%dT%H:%M:%SZ', $(audit_sql_quote "$ts"), '-$(audit_command_match_window_seconds) seconds')
ORDER BY created_at DESC, id DESC
LIMIT 1;
DELETE FROM pending_command_contexts
WHERE id = (
  SELECT id
  FROM pending_command_contexts
  WHERE subcommand = $(audit_sql_quote "$subcommand")
    AND COALESCE(app, '') = $(audit_sql_quote "$app")
    AND args_json = $(audit_sql_quote "$args_json")
    AND created_at >= strftime('%Y-%m-%dT%H:%M:%SZ', $(audit_sql_quote "$ts"), '-$(audit_command_match_window_seconds) seconds')
  ORDER BY created_at DESC, id DESC
  LIMIT 1
);
COMMIT;
SQL
}

