  if [[ "$#" -eq 1 ]]; then
    db_path="$(audit_db_path)"
    sql="$1"
  else
    db_path="$1"
    sql="$2"
  fi

  sqlite3 -tabs "$db_path" <<SQL
.timeout $(audit_busy_timeout_ms)
PRAGMA foreign_keys = ON;
$sql
SQL
}

audit_db_configure_journal_mode() {
