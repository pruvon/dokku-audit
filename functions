  local trigger_name="$1"
  local app_name="$2"
  shift 2

  if "$@"; then
    return 0
  fi

  local exit_code=$?
  audit_warn "failed to record ${trigger_name}${app_name:+ for app '$app_name'}"
  if audit_is_true "$(audit_strict_mode)"; then
    return "$exit_code"
  fi
  return 0
}

audit_extract_config_keys() {
  local token
  local key

  for token in "$@"; do
    key="$token"
    if [[ "$token" == *=* ]]; then
      key="${token%%=*}"
    fi
    printf '%s\n' "$key"
  done
}

