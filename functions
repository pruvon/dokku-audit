audit_print_tsv_table() {
  awk -F '\t' '
    {
      rows[NR] = $0
      if (NF > max_fields) {
        max_fields = NF
      }
      for (col = 1; col <= NF; col++) {
        values[NR "," col] = $col
        if (length($col) > widths[col]) {
          widths[col] = length($col)
        }
      }
    }
    END {
      for (row = 1; row <= NR; row++) {
        for (col = 1; col <= max_fields; col++) {
          value = values[row "," col]
          printf "%s", value
          if (col < max_fields) {
            padding = widths[col] - length(value) + 2
            for (pad = 0; pad < padding; pad++) {
              printf " "
            }
          }
        }
        printf "\n"
      }
    }
  '
}

audit_write_content() {
  local output_path="$1"
  local content="$2"

  if [[ -n "$output_path" ]]; then
    mkdir -p "$(dirname "$output_path")"
    printf '%s\n' "$content" > "$output_path"
    return 0
  fi

  printf '%s\n' "$content"
}

audit_emit_query_output() {
  local format="$1"
  local header_tsv="$2"
  local table_sql="$3"
  local jsonl_sql="$4"
  local json_sql="$5"
  local output_path="$6"
  local quiet="$7"
  local rendered
  local body

  case "$format" in
    table)
      body="$(audit_db_query_tsv "$table_sql")"
      if audit_is_true "$quiet"; then
        rendered="$body"
      else
        rendered="$(
          {
            printf '%s\n' "$header_tsv"
            if [[ -n "$body" ]]; then
              printf '%s\n' "$body"
            fi
          } | audit_print_tsv_table
        )"
      fi
      ;;
    jsonl)
      rendered="$(audit_db_query_raw "$jsonl_sql")"
      ;;
    json)
      rendered="$(audit_db_query_single "$json_sql")"
      ;;
    *)
      audit_die "unsupported format: $format"
      ;;
  esac

  audit_write_content "$output_path" "$rendered"
}

