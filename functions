#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

if [[ -z "${AUDIT_PLUGIN_ROOT:-}" ]]; then
  AUDIT_PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

PLUGIN_AVAILABLE_PATH="$AUDIT_PLUGIN_ROOT"
AUDIT_PLUGIN_NAME="dokku-audit"
AUDIT_DEFAULT_DATA_DIR="/var/lib/dokku/data/dokku-audit"
AUDIT_DEFAULT_BUSY_TIMEOUT_MS="${DOKKU_AUDIT_BUSY_TIMEOUT_MS:-5000}"
AUDIT_DEFAULT_PENDING_STALE_THRESHOLD_SECONDS="${DOKKU_AUDIT_PENDING_STALE_THRESHOLD_SECONDS:-86400}"
AUDIT_DEFAULT_COMMAND_MATCH_WINDOW_SECONDS="${DOKKU_AUDIT_COMMAND_MATCH_WINDOW_SECONDS:-120}"
AUDIT_DEFAULT_STRICT_MODE="${DOKKU_AUDIT_STRICT_MODE:-false}"
AUDIT_DEFAULT_JOURNAL_MODE="${DOKKU_AUDIT_JOURNAL_MODE:-WAL}"
AUDIT_DEFAULT_RUNTIME_USER="${DOKKU_AUDIT_RUNTIME_USER:-dokku}"
AUDIT_DEFAULT_RUNTIME_GROUP="${DOKKU_AUDIT_RUNTIME_GROUP:-$AUDIT_DEFAULT_RUNTIME_USER}"
AUDIT_APPLICATION_ID="1145132356"

audit_plugin_version() {
  if [[ -f "$AUDIT_PLUGIN_ROOT/plugin.toml" ]]; then
    awk -F '"' '/^version = / { print $2; exit }' "$AUDIT_PLUGIN_ROOT/plugin.toml"
    return 0
  fi

  printf '0.1.0\n'
}

audit_data_dir() {
  printf '%s\n' "${DOKKU_AUDIT_DATA_DIR:-${AUDIT_DATA_DIR:-$AUDIT_DEFAULT_DATA_DIR}}"
}

audit_db_path() {
  printf '%s\n' "${DOKKU_AUDIT_DB_PATH:-${AUDIT_DB_PATH:-$(audit_data_dir)/audit.db}}"
}

audit_backup_dir() {
  printf '%s\n' "${DOKKU_AUDIT_BACKUP_DIR:-${AUDIT_BACKUP_DIR:-$(audit_data_dir)/backups}}"
}

audit_lock_file() {
  printf '%s\n' "${DOKKU_AUDIT_LOCK_FILE:-${AUDIT_LOCK_FILE:-$(audit_data_dir)/migrate.lock}}"
}

audit_busy_timeout_ms() {
  printf '%s\n' "$AUDIT_DEFAULT_BUSY_TIMEOUT_MS"
}

audit_pending_stale_threshold_seconds() {
  printf '%s\n' "$AUDIT_DEFAULT_PENDING_STALE_THRESHOLD_SECONDS"
}

audit_command_match_window_seconds() {
  printf '%s\n' "$AUDIT_DEFAULT_COMMAND_MATCH_WINDOW_SECONDS"
}

audit_strict_mode() {
  printf '%s\n' "$AUDIT_DEFAULT_STRICT_MODE"
}

audit_journal_mode_preference() {
  printf '%s\n' "$AUDIT_DEFAULT_JOURNAL_MODE"
}

audit_runtime_user() {
  printf '%s\n' "$AUDIT_DEFAULT_RUNTIME_USER"
}

audit_runtime_group() {
  printf '%s\n' "$AUDIT_DEFAULT_RUNTIME_GROUP"
}

audit_runtime_plugin_name() {
  basename "$AUDIT_PLUGIN_ROOT"
}

audit_dokku_plugin_name() {
  printf '%s\n' "${AUDIT_PLUGIN_NAME#dokku-}"
}

audit_expected_command_name() {
  local subcommand="$1"
  local namespace

  namespace="$(audit_dokku_plugin_name)"
  if [[ "$subcommand" == "default" ]]; then
    printf '%s\n' "$namespace"
    return 0
  fi

  printf '%s:%s\n' "$namespace" "$subcommand"
}

audit_is_command_invocation() {
  local subcommand="$1"
  local actual="${2:-}"

  [[ "$actual" == "$(audit_expected_command_name "$subcommand")" ]]
}

audit_log() {
  printf '%s\n' "$*"
}

audit_warn() {
  printf '%s\n' "${AUDIT_PLUGIN_NAME}: warning: $*" >&2
}

audit_error() {
  printf '%s\n' "${AUDIT_PLUGIN_NAME}: error: $*" >&2
}

audit_die() {
  audit_error "$*"
  return 1
}

audit_has_command() {
  command -v "$1" >/dev/null 2>&1
}

audit_has_user() {
  id -u "$1" >/dev/null 2>&1
}

audit_is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

audit_lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

audit_require_sqlite() {
  audit_has_command sqlite3 || audit_die "sqlite3 executable is required"
}

audit_require_database() {
  local db_path
  db_path="$(audit_db_path)"

  [[ -f "$db_path" ]] || audit_die "database not found at $db_path"
  [[ -r "$db_path" ]] || audit_die "database is not readable at $db_path"
}

audit_now_utc() {
  if [[ -n "${DOKKU_AUDIT_NOW:-}" ]]; then
    printf '%s\n' "$DOKKU_AUDIT_NOW"
    return 0
  fi

  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

audit_days_ago_utc() {
  local days="$1"

  if date -u -d "${days} days ago" +"%Y-%m-%dT%H:%M:%SZ" >/dev/null 2>&1; then
    date -u -d "${days} days ago" +"%Y-%m-%dT%H:%M:%SZ"
    return 0
  fi

  if date -u -v-"${days}"d +"%Y-%m-%dT%H:%M:%SZ" >/dev/null 2>&1; then
    date -u -v-"${days}"d +"%Y-%m-%dT%H:%M:%SZ"
    return 0
  fi

  audit_die "unable to compute relative timestamp for ${days} days"
}

audit_generate_correlation_id() {
  if [[ -n "${DOKKU_AUDIT_CORRELATION_ID:-}" ]]; then
    printf '%s\n' "$DOKKU_AUDIT_CORRELATION_ID"
    return 0
  fi

  printf 'aud_%s_%s\n' "${DOKKU_AUDIT_EPOCH_MS:-$(date +%s)000}" "${DOKKU_AUDIT_RANDOM_HEX:-$(printf '%04x%04x' "$RANDOM" "$RANDOM")}" 
}

audit_sql_quote() {
  local value="$1"

  value=${value//\'/\'\'}
  printf "'%s'" "$value"
}

audit_sql_nullable() {
  local value="${1-}"

  if [[ -z "$value" ]]; then
    printf 'NULL'
    return 0
  fi

  audit_sql_quote "$value"
}

audit_json_escape() {
  local value="$1"

  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

audit_json_string() {
  printf '"%s"' "$(audit_json_escape "$1")"
}

audit_json_or_null() {
  local value="${1-}"

  if [[ -z "$value" ]]; then
    printf 'null'
    return 0
  fi

  audit_json_string "$value"
}

audit_json_array_from_args() {
  local first=1
  local item

  printf '['
  for item in "$@"; do
    if [[ "$first" -eq 0 ]]; then
      printf ','
    fi
    first=0
    audit_json_string "$item"
  done
  printf ']'
}

audit_hostname() {
  if [[ -n "${DOKKU_AUDIT_HOSTNAME:-}" ]]; then
    printf '%s\n' "$DOKKU_AUDIT_HOSTNAME"
    return 0
  fi

  hostname 2>/dev/null || true
}

audit_join_args() {
  local joined=""
  local item

  for item in "$@"; do
    if [[ -n "$joined" ]]; then
      joined+=" "
    fi
    joined+="$item"
  done

  printf '%s\n' "$joined"
}

audit_prefixed_dokku_command_text() {
  local command_text

  command_text="$(audit_join_args "$@")"
  if [[ -z "$command_text" ]]; then
    printf 'dokku\n'
    return 0
  fi

  printf 'dokku %s\n' "$command_text"
}

audit_actor_name_from_ssh_context() {
  local ssh_name="${1:-}"
  local ssh_user="${2:-}"

  if [[ -n "$ssh_name" ]]; then
    printf '%s\n' "$ssh_name"
    return 0
  fi

  printf '%s\n' "$ssh_user"
}

audit_actor_source_from_ssh_context() {
  local ssh_name="${1:-}"
  local ssh_user="${2:-}"

  if [[ -n "$ssh_name" ]]; then
    printf 'SSH_NAME\n'
    return 0
  fi

  if [[ -n "$ssh_user" ]]; then
    printf 'SSH_USER\n'
    return 0
  fi

  printf '\n'
}

audit_actor_type_from_name() {
  if [[ -n "${1:-}" ]]; then
    printf 'user\n'
    return 0
  fi

  printf 'system\n'
}

audit_command_tokens_lines() {
  local -a split_tokens=()

  if [[ "$#" -eq 0 ]]; then
    return 0
  fi

  if [[ "$#" -eq 1 ]] && [[ -n "$1" ]] && [[ "$1" == *" "* ]]; then
    IFS=' ' read -r -a split_tokens <<< "$1"
    printf '%s\n' "${split_tokens[@]}"
    return 0
  fi

  printf '%s\n' "$@"
}

audit_redact_assignment_token() {
  local token="$1"

  if [[ "$token" != *=* ]]; then
    printf '%s\n' "$token"
    return 0
  fi

  printf '%s=[REDACTED]\n' "${token%%=*}"
}

AUDIT_PARSED_TOKENS=()
AUDIT_PARSED_TRAILING_TOKENS=()
AUDIT_PARSED_COMMAND_ARGS=()
AUDIT_PARSED_MATCH_ARGS=()
AUDIT_PARSED_GLOBAL_APP=""
AUDIT_PARSED_SUBCOMMAND=""
AUDIT_PARSED_APP=""
AUDIT_PARSED_CONTAINER_TYPE=""
AUDIT_PARSED_CONTAINER_ID=""

audit_parse_run_arguments() {
  local global_app="$1"
  shift || true
  local -a remaining=("$@")
  local token
  local idx=0

  AUDIT_PARSED_APP="$global_app"
  AUDIT_PARSED_COMMAND_ARGS=()
  AUDIT_PARSED_MATCH_ARGS=()

  while [[ "$idx" -lt "${#remaining[@]}" ]]; do
    token="${remaining[$idx]}"
    case "$token" in
      -e|--env|--ttl-seconds)
        idx=$((idx + 2))
        continue
        ;;
      --env=*|--ttl-seconds=*|--no-tty|--force-tty)
        idx=$((idx + 1))
        continue
        ;;
      --)
        idx=$((idx + 1))
        break
        ;;
      -*)
        idx=$((idx + 1))
        continue
        ;;
      *)
        if [[ -z "$AUDIT_PARSED_APP" ]]; then
          AUDIT_PARSED_APP="$token"
          idx=$((idx + 1))
          continue
        fi
        break
        ;;
    esac
  done

  AUDIT_PARSED_COMMAND_ARGS=("${remaining[@]:$idx}")
  AUDIT_PARSED_MATCH_ARGS=("${AUDIT_PARSED_COMMAND_ARGS[@]}")
}

audit_parse_enter_arguments() {
  local global_app="$1"
  shift || true
  local -a remaining=("$@")
  local token
  local idx=0

  AUDIT_PARSED_APP="$global_app"
  AUDIT_PARSED_CONTAINER_TYPE=""
  AUDIT_PARSED_CONTAINER_ID=""
  AUDIT_PARSED_COMMAND_ARGS=()
  AUDIT_PARSED_MATCH_ARGS=()

  if [[ -z "$AUDIT_PARSED_APP" ]] && [[ "${#remaining[@]}" -gt 0 ]]; then
    AUDIT_PARSED_APP="${remaining[0]}"
    idx=1
  fi

  AUDIT_PARSED_MATCH_ARGS=("${remaining[@]:$idx}")

  if [[ "$idx" -lt "${#remaining[@]}" ]]; then
    token="${remaining[$idx]}"
    case "$token" in
      --container-id)
        if [[ $((idx + 1)) -lt ${#remaining[@]} ]]; then
          AUDIT_PARSED_CONTAINER_ID="${remaining[$((idx + 1))]}"
        fi
        idx=$((idx + 2))
        ;;
      --container-id=*)
        AUDIT_PARSED_CONTAINER_ID="${token#--container-id=}"
        idx=$((idx + 1))
        ;;
      --)
        idx=$((idx + 1))
        ;;
      -*)
        idx=$((idx + 1))
        ;;
      *)
        AUDIT_PARSED_CONTAINER_TYPE="$token"
        idx=$((idx + 1))
        ;;
    esac
  fi

  AUDIT_PARSED_COMMAND_ARGS=("${remaining[@]:$idx}")
}

audit_command_uses_first_positional_app() {
  local subcommand="${1:-}"

  case "$subcommand" in
    config:set-global|config:unset-global)
      return 1
      ;;
    config|config:*|resource:*|domains|domains:*|ports:*|proxy:*|ps:*|logs|checks:*|nginx:*|docker-options:*|storage:*|network:*|git:*|builder:*|certs:*|letsencrypt:*)
      return 0
      ;;
  esac

  return 1
}

audit_parse_generic_arguments() {
  local subcommand="$1"
  local global_app="$2"
  shift 2 || true
  local -a remaining=("$@")

  AUDIT_PARSED_APP="$global_app"
  AUDIT_PARSED_COMMAND_ARGS=("${remaining[@]}")
  AUDIT_PARSED_MATCH_ARGS=("${remaining[@]}")

  if ! audit_command_uses_first_positional_app "$subcommand"; then
    return 0
  fi

  if [[ -z "$AUDIT_PARSED_APP" ]] && [[ "${#remaining[@]}" -gt 0 ]] && [[ -n "${remaining[0]}" ]] && [[ "${remaining[0]}" != -* ]]; then
    AUDIT_PARSED_APP="${remaining[0]}"
    AUDIT_PARSED_COMMAND_ARGS=("${remaining[@]:1}")
    AUDIT_PARSED_MATCH_ARGS=("${AUDIT_PARSED_COMMAND_ARGS[@]}")
  fi
}

audit_parse_dokku_invocation() {
  local -a tokens=("$@")
  local -a remaining=()
  local token
  local idx=0

  AUDIT_PARSED_TOKENS=("${tokens[@]}")
  AUDIT_PARSED_TRAILING_TOKENS=()
  AUDIT_PARSED_COMMAND_ARGS=()
  AUDIT_PARSED_MATCH_ARGS=()
  AUDIT_PARSED_GLOBAL_APP=""
  AUDIT_PARSED_SUBCOMMAND=""
  AUDIT_PARSED_APP=""
  AUDIT_PARSED_CONTAINER_TYPE=""
  AUDIT_PARSED_CONTAINER_ID=""

  while [[ "$idx" -lt "${#tokens[@]}" ]]; do
    token="${tokens[$idx]}"
    case "$token" in
      --app)
        if [[ $((idx + 1)) -lt ${#tokens[@]} ]]; then
          AUDIT_PARSED_GLOBAL_APP="${tokens[$((idx + 1))]}"
        fi
        idx=$((idx + 2))
        continue
        ;;
      --app=*)
        AUDIT_PARSED_GLOBAL_APP="${token#--app=}"
        idx=$((idx + 1))
        continue
        ;;
      --label|--remote)
        idx=$((idx + 2))
        continue
        ;;
      --label=*|--remote=*|--quiet|--trace|--force|--global)
        idx=$((idx + 1))
        continue
        ;;
      *)
        AUDIT_PARSED_SUBCOMMAND="$token"
        idx=$((idx + 1))
        break
        ;;
    esac
  done

  remaining=("${tokens[@]:$idx}")
  AUDIT_PARSED_TRAILING_TOKENS=("${remaining[@]}")

  case "$AUDIT_PARSED_SUBCOMMAND" in
    run|run:detached)
      audit_parse_run_arguments "$AUDIT_PARSED_GLOBAL_APP" "${remaining[@]}"
      ;;
    enter)
      audit_parse_enter_arguments "$AUDIT_PARSED_GLOBAL_APP" "${remaining[@]}"
      ;;
    *)
      audit_parse_generic_arguments "$AUDIT_PARSED_SUBCOMMAND" "$AUDIT_PARSED_GLOBAL_APP" "${remaining[@]}"
      ;;
  esac
}

audit_sanitized_dokku_command_tokens_lines() {
  local -a tokens=("$@")
  local -a sanitized=()
  local subcommand=""
  local token
  local next_token
  local command_seen=0
  local idx=0

  audit_parse_dokku_invocation "${tokens[@]}"
  subcommand="$AUDIT_PARSED_SUBCOMMAND"

  while [[ "$idx" -lt "${#tokens[@]}" ]]; do
    token="${tokens[$idx]}"

    if [[ "$command_seen" -eq 0 ]]; then
      sanitized+=("$token")
      if [[ -n "$subcommand" ]] && [[ "$token" == "$subcommand" ]]; then
        command_seen=1
      fi
      idx=$((idx + 1))
      continue
    fi

    case "$subcommand" in
      config:set|config:set-global)
        sanitized+=("$(audit_redact_assignment_token "$token")")
        idx=$((idx + 1))
        ;;
      run|run:detached)
        case "$token" in
          -e|--env)
            sanitized+=("$token")
            idx=$((idx + 1))
            if [[ "$idx" -lt "${#tokens[@]}" ]]; then
              next_token="${tokens[$idx]}"
              if [[ "$next_token" == *=* ]]; then
                sanitized+=("$(audit_redact_assignment_token "$next_token")")
              else
                sanitized+=("$next_token")
              fi
            fi
            idx=$((idx + 1))
            ;;
          --env=*)
            next_token="${token#--env=}"
            if [[ "$next_token" == *=* ]]; then
              sanitized+=("--env=$(audit_redact_assignment_token "$next_token")")
            else
              sanitized+=("$token")
            fi
            idx=$((idx + 1))
            ;;
          *)
            sanitized+=("$token")
            idx=$((idx + 1))
            ;;
        esac
        ;;
      *)
        sanitized+=("$token")
        idx=$((idx + 1))
        ;;
    esac
  done

  printf '%s\n' "${sanitized[@]}"
}

audit_sanitized_dokku_command_text() {
  local -a sanitized_tokens=()
  local token

  while IFS= read -r token; do
    sanitized_tokens+=("$token")
  done < <(audit_sanitized_dokku_command_tokens_lines "$@")

  audit_join_args "${sanitized_tokens[@]}"
}

audit_should_record_user_auth_command() {
  local subcommand="${1:-}"
  local app="${2:-}"
  shift 2 || true

  case "$subcommand" in
    run|run:detached|enter)
      return 0
      ;;
    ""|-*)
      return 1
      ;;
    audit|audit:*|help|version|report|logs|config|apps:list|apps:exists|ps:retire|*:list|*:report|*:info|*:show|*:exists|*:links|*:app-links)
      return 1
      ;;
    resource:limit)
      [[ -n "$app" ]] || return 1
      [[ "$#" -gt 0 ]] || return 1
      return 0
      ;;
  esac

  return 0
}

audit_command_event_meta_json() {
  local actor_source="$1"
  local command_text="$2"
  local subcommand="$3"
  local args_json="$4"
  local container_type="$5"
  local container_id="$6"
  local hostname="$7"
  local success_hint="$8"

  if [[ -z "$args_json" ]]; then
    args_json='[]'
  fi

  printf '{"actor_source":%s,"command":%s,"subcommand":%s,"args":%s,"container_type":%s,"container_id":%s,"hostname":%s,"success_hint":%s}' \
    "$(audit_json_or_null "$actor_source")" \
    "$(audit_json_or_null "$command_text")" \
    "$(audit_json_or_null "$subcommand")" \
    "$args_json" \
    "$(audit_json_or_null "$container_type")" \
    "$(audit_json_or_null "$container_id")" \
    "$(audit_json_or_null "$hostname")" \
    "$(audit_json_or_null "$success_hint")"
}

audit_message_for_command_invoke() {
  local command_text="${1:-}"
  local subcommand="${2:-}"

  if [[ -n "$command_text" ]]; then
    printf '%s\n' "$command_text"
    return 0
  fi

  if [[ -n "$subcommand" ]]; then
    printf 'dokku %s\n' "$subcommand"
    return 0
  fi

  printf 'dokku command\n'
}

audit_message_for_run() {
  printf 'dokku run scheduled\n'
}

audit_message_for_enter() {
  printf 'dokku enter requested\n'
}

audit_message_for_deploy_finish() {
  local classification="$1"

  if [[ "$classification" == "source_deploy" ]]; then
    printf 'source deploy finished\n'
    return 0
  fi

  printf 'release-only deploy finished\n'
}

audit_message_for_config_change() {
  local action="$1"
  shift

  if [[ "$#" -eq 0 ]]; then
    printf 'config keys %s\n' "$action"
    return 0
  fi

  printf 'config keys %s: %s\n' "$action" "$(printf '%s, ' "$@" | sed 's/, $//')"
}

audit_message_for_domains_change() {
  local action="$1"
  shift

  if [[ "$#" -eq 0 ]]; then
    printf 'domains %s\n' "$action"
    return 0
  fi

  printf 'domains %s: %s\n' "$action" "$(printf '%s, ' "$@" | sed 's/, $//')"
}

audit_message_for_ports_change() {
  printf 'ports %s\n' "$1"
}

audit_mkdirs() {
  local data_dir
  local backup_dir
  local runtime_user
  local runtime_group

  data_dir="$(audit_data_dir)"
  backup_dir="$(audit_backup_dir)"
  runtime_user="$(audit_runtime_user)"
  runtime_group="$(audit_runtime_group)"

  mkdir -p "$data_dir" "$backup_dir"

  if audit_has_user "$runtime_user"; then
    chown "$runtime_user:$runtime_group" "$data_dir" "$backup_dir" 2>/dev/null || chown "$runtime_user" "$data_dir" "$backup_dir" 2>/dev/null || true
    chmod 0770 "$data_dir" "$backup_dir" 2>/dev/null || true
    return 0
  fi

  chmod 0750 "$data_dir" "$backup_dir" 2>/dev/null || true
}

audit_set_db_permissions() {
  local db_path
  local runtime_user
  local runtime_group

  db_path="$(audit_db_path)"
  runtime_user="$(audit_runtime_user)"
  runtime_group="$(audit_runtime_group)"

  if [[ -f "$db_path" ]]; then
    if audit_has_user "$runtime_user"; then
      chown "$runtime_user:$runtime_group" "$db_path" 2>/dev/null || chown "$runtime_user" "$db_path" 2>/dev/null || true
      chmod 0660 "$db_path" 2>/dev/null || true
    else
      chmod 0640 "$db_path" 2>/dev/null || true
    fi
  fi

  if [[ -f "${db_path}-wal" ]]; then
    if audit_has_user "$runtime_user"; then
      chown "$runtime_user:$runtime_group" "${db_path}-wal" 2>/dev/null || chown "$runtime_user" "${db_path}-wal" 2>/dev/null || true
      chmod 0660 "${db_path}-wal" 2>/dev/null || true
    else
      chmod 0640 "${db_path}-wal" 2>/dev/null || true
    fi
  fi

  if [[ -f "${db_path}-shm" ]]; then
    if audit_has_user "$runtime_user"; then
      chown "$runtime_user:$runtime_group" "${db_path}-shm" 2>/dev/null || chown "$runtime_user" "${db_path}-shm" 2>/dev/null || true
      chmod 0660 "${db_path}-shm" 2>/dev/null || true
    else
      chmod 0640 "${db_path}-shm" 2>/dev/null || true
    fi
  fi
}

audit_db_exec() {
  local db_path
  local sql

  if [[ "$#" -eq 1 ]]; then
    db_path="$(audit_db_path)"
    sql="$1"
  else
    db_path="$1"
    sql="$2"
  fi

  sqlite3 "$db_path" <<SQL
.timeout $(audit_busy_timeout_ms)
PRAGMA foreign_keys = ON;
$sql
SQL
}

audit_db_query_single() {
  local db_path
  local sql
  local output

  if [[ "$#" -eq 1 ]]; then
    db_path="$(audit_db_path)"
    sql="$1"
  else
    db_path="$1"
    sql="$2"
  fi

  output="$(audit_db_exec "$db_path" "$sql")"
  printf '%s\n' "$output" | awk 'NR == 1 { print; exit }'
}

audit_db_query_raw() {
  local db_path
  local sql

  if [[ "$#" -eq 1 ]]; then
    db_path="$(audit_db_path)"
    sql="$1"
  else
    db_path="$1"
    sql="$2"
  fi

  audit_db_exec "$db_path" "$sql"
}

audit_db_query_tsv() {
  local db_path
