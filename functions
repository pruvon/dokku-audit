audit_with_lock() {
  local lock_file="$1"
  shift
  local result

  mkdir -p "$(dirname "$lock_file")"

  if audit_has_command flock; then
    exec 9>"$lock_file"
    flock -w 30 9 || audit_die "failed to acquire lock: $lock_file"
    set +e
    "$@"
    result=$?
    set -e
    flock -u 9 || true
    exec 9>&-
    return "$result"
  fi

  if ! mkdir "${lock_file}.d" 2>/dev/null; then
    audit_die "failed to acquire lock and flock is unavailable: $lock_file"
    return 1
  fi

  set +e
  "$@"
  result=$?
  set -e
  rmdir "${lock_file}.d" || true
  return "$result"
}

audit_migration_files() {
  local file

  for file in "$AUDIT_PLUGIN_ROOT"/migrations/[0-9][0-9][0-9]_*.sql; do
    [[ -f "$file" ]] || continue
    printf '%s\n' "$file"
  done | LC_ALL=C sort
}

audit_latest_migration_version() {
  local latest=0
  local file
  local version

  while IFS= read -r file; do
    version="$(basename "$file" | cut -d '_' -f 1)"
    latest="$((10#$version))"
  done < <(audit_migration_files)

  printf '%s\n' "$latest"
}

audit_run_migrations_locked() {
  local dry_run="$1"
  local verbose="$2"
  local db_path
  local preexisting=0
  local current_version=0
  local previous_version=0
  local current_application_id=0
  local applied=0
  local last_applied=0
  local migration_file
  local version
  local sql
  local migration_time

  db_path="$(audit_db_path)"

  if [[ -s "$db_path" ]]; then
    preexisting=1
    current_application_id="$(audit_application_id_current)"
    if [[ -z "$current_application_id" ]]; then
      audit_die "failed to read application_id from existing database"
      return 1
    fi
    if [[ "$current_application_id" != "$AUDIT_APPLICATION_ID" ]]; then
      audit_die "database application_id mismatch at $db_path: expected $AUDIT_APPLICATION_ID, got $current_application_id"
      return 1
    fi
    current_version="$(audit_user_version)"
  fi
  previous_version="$current_version"

  if audit_is_true "$dry_run"; then
    while IFS= read -r migration_file; do
      version="$(basename "$migration_file" | cut -d '_' -f 1)"
      if (( 10#$version > current_version )); then
        printf 'would apply %s\n' "$(basename "$migration_file")"
      fi
    done < <(audit_migration_files)
    printf 'current_version=%s target_version=%s\n' "$current_version" "$(audit_latest_migration_version)"
    return 0
  fi

  audit_mkdirs

  if [[ ! -f "$db_path" ]]; then
    : > "$db_path"
  fi

  audit_set_db_permissions
  audit_db_exec "PRAGMA application_id = $AUDIT_APPLICATION_ID;"

  while IFS= read -r migration_file; do
    version="$(basename "$migration_file" | cut -d '_' -f 1)"
    if (( 10#$version <= current_version )); then
      continue
    fi

    sql="$(<"$migration_file")"

    if audit_is_true "$verbose"; then
      printf 'applying %s\n' "$(basename "$migration_file")"
    fi

    audit_db_exec "BEGIN IMMEDIATE;
$sql
PRAGMA user_version = $((10#$version));
COMMIT;"

    current_version="$((10#$version))"
    applied=$((applied + 1))
    last_applied="$current_version"
  done < <(audit_migration_files)

  audit_db_configure_journal_mode >/dev/null
  audit_db_exec 'PRAGMA optimize;'

  migration_time="$(audit_now_utc)"
  audit_meta_set "plugin_version" "$(audit_plugin_version)"
  audit_meta_set "last_optimize_at" "$migration_time"
  if [[ "$preexisting" -eq 0 ]]; then
    audit_meta_set "db_initialized_at" "$migration_time"
  fi
  if [[ "$applied" -gt 0 ]]; then
    audit_meta_set "last_migration_at" "$migration_time"
    audit_meta_set "last_migration_from" "$previous_version"
    audit_meta_set "last_migration_to" "$last_applied"
    audit_insert_maintenance_event \
      "migrate" \
      "maintenance_migrate" \
      "applied ${applied} migration(s)" \
      "{\"previous_version\":${previous_version},\"new_version\":${last_applied},\"applied_count\":${applied}}"
  fi

  printf '%s\n' "$current_version"
}

audit_run_migrations() {
  local dry_run="${1:-false}"
  local verbose="${2:-false}"

  audit_require_sqlite
  audit_with_lock "$(audit_lock_file)" audit_run_migrations_locked "$dry_run" "$verbose"
}

audit_pretty_json() {
  local input="$1"

  if audit_has_command python3; then
    python3 -c 'import json, sys; print(json.dumps(json.loads(sys.argv[1]), indent=2, sort_keys=True))' "$input"
    return 0
  fi

  printf '%s\n' "$input"
}

