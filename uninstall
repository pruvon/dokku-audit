#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

if [[ -n "${1:-}" ]] && [[ "$1" != "$AUDIT_PLUGIN_NAME" ]] && [[ "$1" != "$(audit_runtime_plugin_name)" ]] && [[ "$1" != "$(audit_dokku_plugin_name)" ]]; then
  audit_die "unexpected plugin name '$1'"
fi

audit_log "${AUDIT_PLUGIN_NAME}: preserved database at $(audit_db_path)"
