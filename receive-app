#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

AUDIT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$AUDIT_SCRIPT_DIR/bootstrap"

audit_handle_receive_app() {
  local app="$1"
  local rev="${2:-}"
  local ts
  local actor_type="system"
  local actor_name=""
  local correlation_id
  local metadata_json
  local meta_json

  [[ -n "$app" ]] || audit_die "missing app name"

  ts="$(audit_now_utc)"
  correlation_id="$(audit_pending_correlation_id "$app")"
  if [[ -z "$correlation_id" ]]; then
    correlation_id="$(audit_generate_correlation_id)"
  fi
  metadata_json='{"received_via":"receive-app"}'
  meta_json="{\"received_via\":\"receive-app\",\"rev\":$(audit_json_or_null "$rev") }"
  audit_claim_pending_event_actor_context "$app" "deploy-receive" "$ts"
  actor_type="$AUDIT_CONTEXT_ACTOR_TYPE"
  actor_name="$AUDIT_CONTEXT_ACTOR_NAME"
  meta_json="$(audit_json_patch_objects "$meta_json" "$AUDIT_CONTEXT_ACTOR_META_JSON")"

  audit_db_exec "BEGIN IMMEDIATE;
INSERT INTO pending_deploys(
  app,
  correlation_id,
  source_type,
  rev,
  metadata_json,
  first_seen_ts,
  updated_ts
) VALUES (
  $(audit_sql_quote "$app"),
  $(audit_sql_quote "$correlation_id"),
  NULL,
  $(audit_sql_nullable "$rev"),
  $(audit_sql_quote "$metadata_json"),
  $(audit_sql_quote "$ts"),
  $(audit_sql_quote "$ts")
) ON CONFLICT(app) DO UPDATE SET
  correlation_id = excluded.correlation_id,
  source_type = COALESCE(pending_deploys.source_type, excluded.source_type),
  rev = COALESCE(excluded.rev, pending_deploys.rev),
  metadata_json = json_patch(COALESCE(pending_deploys.metadata_json, '{}'), json(excluded.metadata_json)),
  updated_ts = excluded.updated_ts;
INSERT INTO events (
  ts,
  app,
  category,
  action,
  status,
  classification,
  source_trigger,
  source_type,
  image_tag,
  rev,
  actor_type,
  actor_name,
  correlation_id,
  message,
  meta_json,
  created_at
) VALUES (
  $(audit_sql_quote "$ts"),
  $(audit_sql_quote "$app"),
  'deploy',
  'receive',
  'success',
  'source_received',
  'receive-app',
  NULL,
  NULL,
  $(audit_sql_nullable "$rev"),
  $(audit_sql_quote "$actor_type"),
  $(audit_sql_nullable "$actor_name"),
  $(audit_sql_quote "$correlation_id"),
  'source received',
  $(audit_sql_quote "$meta_json"),
  $(audit_sql_quote "$ts")
);
COMMIT;"
}

audit_trigger_guard "receive-app" "${1:-}" audit_handle_receive_app "$@"
